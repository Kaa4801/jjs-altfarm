        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= LocalPlayer then
                count = count + 1
                local pBtn = Instance.new("TextButton")
                pBtn.Parent = DropdownScroll
                pBtn.Size = UDim2.new(1, 0, 0, 25)
                pBtn.Position = UDim2.new(0, 0, 0, (count - 1) * 25)
