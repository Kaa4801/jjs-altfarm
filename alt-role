    local function startCFlyLock()
        while farming do
            task.wait(0.1)
            local char = LocalPlayer.Character
            local hrp = char and char:FindFirstChild("HumanoidRootPart")
            local hum = char and char:FindFirstChildOfClass("Humanoid")
            
            if hrp and hum and targetPlayer and targetPlayer.Character then
                local targetHrp = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
                if targetHrp then
                    hum.Health = 1
                    
                    local targetHeight = hrp.Position.Y + 805
                    while farming and hrp and targetPlayer.Character and hrp.Position.Y < targetHeight do
                        if hum.Health ~= 1 then hum.Health = 1 end
                        hrp.CFrame = hrp.CFrame + Vector3.new(0, upSpeed, 0)
                        hrp.Velocity = Vector3.new(0, 0, 0)
                        RunService.Heartbeat:Wait()
                    end
                    
                    while farming and targetPlayer.Character and targetHrp do
                        if hum.Health ~= 1 then hum.Health = 1 end
                        local targetTopPos = Vector3.new(targetHrp.Position.X, hrp.Position.Y, targetHrp.Position.Z)
                        local dist = (Vector3.new(hrp.Position.X, hrp.Position.Y, hrp.Position.Z) - targetTopPos).Magnitude
                        
                        if dist > 6 then
                            local dir = (targetTopPos - hrp.Position).Unit
                            hrp.CFrame = CFrame.new(hrp.Position + (dir * math.min(flySpeed, dist)))
                        else
                            break 
                        end
                        hrp.Velocity = Vector3.new(0, 0, 0)
                        RunService.Heartbeat:Wait()
                    end
                    
                    local deadStateActivated = false 
                    while farming and targetPlayer.Character and targetHrp do
                        local torsoCFrame = targetHrp.CFrame * CFrame.new(0, 0, -3.5)
                        local distance = (hrp.Position - torsoCFrame.Position).Magnitude
                        
                        if distance > 2.0 then
                            local direction = (torsoCFrame.Position - hrp.Position).Unit
                            hrp.CFrame = CFrame.new(hrp.Position + (direction * math.min(snapSpeed, distance)), targetHrp.Position)
                        else
                            hrp.CFrame = CFrame.new(torsoCFrame.Position, targetHrp.Position) * CFrame.Angles(0, math.rad(180), 0)
                            if not deadStateActivated and char and char:FindFirstChild("Humanoid") then
                                deadStateActivated = true
                                char.Humanoid:ChangeState(Enum.HumanoidStateType.Dead)
                            end
                        end
                        hrp.Velocity = Vector3.new(0, 0, 0)
                        RunService.Heartbeat:Wait()
                    end
                end
            end
        end
    end

